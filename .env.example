# ForgeGuard Faster Whisper Server — environment configuration.
# Every setting is a plain (unprefixed) environment variable read at startup.
# Copy to .env for reference; pass these through your compose/run environment.

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Persistent, writable state dir: TLS cert/key (<DATA_DIR>/tls) and the active
# model choice (<DATA_DIR>/active_model). In the container this is a volume.
DATA_DIR=/data
# UVICORN_ROOT_PATH=/whisper           # set when served behind a reverse-proxy prefix

# --- Model / inference ---
MODEL_SIZE=large-v3                     # tiny|base|small|medium|large-v3|large-v3-turbo|distil-large-v3
DEVICE=cuda                             # cuda|cpu|auto
# COMPUTE_TYPE=float16                  # default: float16 on cuda, int8 on cpu
BEAM_SIZE=5
# DEFAULT_LANGUAGE=en                   # empty => auto-detect
ENABLE_VAD_FILTER=true
WARMUP_ON_START=true                    # warm the model in the background at boot
# MODEL_DIR=/app/models                 # baked-model dir; empty forces hub download
# MODEL_REVISION=                       # pin a HF git revision for hub downloads

# --- Concurrency / admission ---
MAX_CONCURRENCY=1                       # active transcriptions at once (GPU: 1)
QUEUE_SIZE=32                           # max requests waiting for a slot
QUEUE_TIMEOUT_S=120

# --- Security ---
# API_KEY=change-me                     # empty => API auth disabled (open)
MAX_UPLOAD_BYTES=26214400               # 25 MB; 0 disables the cap

# --- Privacy / responsible use (STT transcripts are sensitive PII) ---
LOG_INPUT_TEXT=false                    # do NOT log transcript text (keep off)
PERSIST_AUDIO=false                     # never keep uploaded audio beyond the request
RETENTION_DAYS=0                        # reserved for any stored artifacts; 0 = keep

# --- Web console ---
ENABLE_WEB_UI=true
# WEBUI_DIST_DIR=/app/webui_dist        # built static assets

# --- TLS (built-in HTTPS) ---
# When enabled the server speaks HTTPS directly (uvicorn SSL). With no cert
# supplied a self-signed one is generated on first run and persisted under
# <DATA_DIR>/tls so restarts reuse it — no reverse proxy or manual openssl.
# Point CERT/KEY at a real cert for anything public.
TLS_ENABLED=false
TLS_SELF_SIGNED=true                    # auto-generate if cert/key missing
# TLS_CERT_FILE=/data/tls/cert.pem      # defaults to <DATA_DIR>/tls/cert.pem
# TLS_KEY_FILE=/data/tls/key.pem        # defaults to <DATA_DIR>/tls/key.pem
TLS_CN=localhost                        # CN + SAN of the generated cert
# TLS_SAN=whisper.local,192.168.1.50    # extra SANs (comma-separated)
